{
  "name": "pebble-backend",
  "version": "1.0.0",
  "description": "Pebble - UMC 10th Node.js Backend",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "lint": "eslint src --ext .ts",
